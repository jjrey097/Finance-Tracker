# ── Supabase PostgreSQL ─────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → Database → Connection string
# Use the "URI" format and append ?sslmode=require
ConnectionStrings__DefaultConnection=Host=db.<project>.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=<password>;SSL Mode=Require;Trust Server Certificate=true

# ── Clerk ────────────────────────────────────────────────────────────────────
# Found in: Clerk dashboard → API Keys
# Format: https://<your-clerk-subdomain>.clerk.accounts.dev
Clerk__Authority=https://<your-clerk-subdomain>.clerk.accounts.dev

# Frontend build-time key (also set this in Railway as a build variable)
# Found in: Clerk dashboard → API Keys → Publishable key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── CORS ─────────────────────────────────────────────────────────────────────
# Your Railway app URL — set after first deploy
# Format: AllowedOrigins__0=https://your-app.up.railway.app
AllowedOrigins__0=https://your-app.up.railway.app
